# macOS / IDE
.DS_Store
.vscode/
.idea/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# Generated lockfiles (cycle-0 decision: pyproject.toml is the source of
# truth; lockfiles are local tooling state, not deliverables — see
# specs/pitches/0000-rebrand-stabilize/pitch.md § Open questions Q1).
uv.lock
poetry.lock
Pipfile.lock

# AI-NEMO local state (cycle-1+ TM database, usage telemetry,
# cycle-3+ Kuzu termbase under ``.ainemo/termbase.kuzu/``).
# Per AGENTS.md § Translation-Domain Conventions: TM is opt-in for
# git tracking, not default.
.ainemo/

# Benchmark result JSON files — per-host artifacts written by the
# opt-in benchmark suite (``pytest -m benchmark``). Track regressions
# by diffing successive local runs or capturing the JSON in PR
# comments; the files themselves are not deliverables.
tests/benchmarks/results/

# Gradle build outputs and per-host caches under the gradle-plugin
# module. The wrapper itself (``gradlew``, ``gradlew.bat``,
# ``gradle/wrapper/``) is committed; everything below is generated.
gradle-plugin/.gradle/
gradle-plugin/build/
gradle-plugin/.kotlin/

# --- doc_internal/ ---
# Per the global agent manifest convention: internal reference docs
# (session notes, manual test plans, working drafts) live here and stay
# local-only. Promote individual artifacts into specs/ or docs/ if they
# graduate from "private working layer" to "team-shared context."
doc_internal/
